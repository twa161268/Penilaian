<!DOCTYPE html>
<html>
<head>
    <title>Ref Nilai</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-size: 13px;
        }

        .form-control {
            padding: 3px 6px;
            font-size: 13px;
            height: 30px;
        }

        .row {
            margin-bottom: 6px !important;
        }

        .label-text {
            display: flex;
            align-items: center;
        }

        .container-box {
            max-width: 420px;
        }

        h4 {
            font-size: 16px;
        }

        .btn {
            padding: 5px;
            font-size: 13px;
        }
    </style>
</head>

<body class="bg-light">

<div class="container mt-3 container-box">
    <h4 class="mb-3 text-center">Parameter Penilaian</h4>

    <form id="formRef">

        <div class="row">
            <div class="col-6 label-text">Nilai Bonus</div>
            <div class="col-6"><input name="nilaibonus" class="form-control"></div>
        </div>

        <div class="row">
            <div class="col-6 label-text">Cuti Sakit</div>
            <div class="col-6"><input name="cutisakita" class="form-control"></div>
        </div>

        <div class="row">
            <div class="col-6 label-text">Telat > 30 Menit</div>
            <div class="col-6"><input name="telatu30a" class="form-control"></div>
        </div>

        <div class="row">
            <div class="col-6 label-text">Telat < 30 Menit</div>
            <div class="col-6"><input name="telatd30a" class="form-control"></div>
        </div>

        <div class="row">
            <div class="col-6 label-text">Telat > 60 Menit</div>
            <div class="col-6"><input name="telatu60a" class="form-control"></div>
        </div>

        <div class="row">
            <div class="col-6 label-text">Lupa Absen</div>
            <div class="col-6"><input name="lupaa" class="form-control"></div>
        </div>

        <div class="row">
            <div class="col-6 label-text">Hadir Full</div>
            <div class="col-6"><input name="hadirfulla" class="form-control"></div>
        </div>

        <div class="row">
            <div class="col-6 label-text">Ontime</div>
            <div class="col-6"><input name="ontimea" class="form-control"></div>
        </div>

        <div class="row">
            <div class="col-6 label-text">Overtime</div>
            <div class="col-6"><input name="ovrmnta" class="form-control"></div>
        </div>

        <div class="row">
            <div class="col-6 label-text">Kerja Hari Libur</div>
            <div class="col-6"><input name="kerjalibura" class="form-control"></div>
        </div>

        <div class="row">
            <div class="col-6 label-text">Lalai</div>
            <div class="col-6"><input name="lalaia" class="form-control"></div>
        </div>

        <div class="row">
            <div class="col-6 label-text">Tunda Pekerjaan</div>
            <div class="col-6"><input name="tundaa" class="form-control"></div>
        </div>

        <div class="row mb-2">
            <div class="col-6 label-text">Alpha</div>
            <div class="col-6"><input name="alphaa" class="form-control"></div>
        </div>

        <button type="submit" class="btn btn-primary w-100">Simpan</button>

    </form>
</div>

<script src="/js/reffnilai.js"></script>

</body>
</html>