<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
        <meta name="description" content="" />
        <meta name="author" content="" />
        <title>Start Penilaian Karyawan</title>
        <!-- Favicon-->
        <link rel="icon" type="image/x-icon" href="assets/favicon.ico" />
        <!-- Bootstrap Icons-->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css" rel="stylesheet" />
        <!-- Google fonts-->
        <link href="https://fonts.googleapis.com/css?family=Merriweather+Sans:400,700" rel="stylesheet" />
        <link href="https://fonts.googleapis.com/css?family=Merriweather:400,300,300italic,400italic,700,700italic" rel="stylesheet" type="text/css" />
        <!-- SimpleLightbox plugin CSS-->
        <link href="https://cdnjs.cloudflare.com/ajax/libs/SimpleLightbox/2.1.0/simpleLightbox.min.css" rel="stylesheet" />
        <!-- Core theme CSS (includes Bootstrap)-->
        <link href="/css/styles.css" rel="stylesheet" />

        <style>
        .nav-btn.disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
        </style>



    </head>
    <!--<body id="page-top">-->
    <body id="page-top" data-login="<%= isLogin %>">
        <!-- Navigation-->
        <nav class="navbar navbar-expand-lg navbar-light fixed-top py-3" id="mainNav">
            <div class="container px-4 px-lg-5">
                <a class="navbar-brand" href="#page-top">Form Penilaian Kinerja Karyawan</a>
                <button class="navbar-toggler navbar-toggler-right" type="button" data-bs-toggle="collapse" data-bs-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
                <div class="collapse navbar-collapse" id="navbarResponsive">
                    <ul class="navbar-nav ms-auto my-2 my-lg-0">
                        <li class="nav-item"><a class="nav-link" href="#about">About</a></li>
                        <li class="nav-item"><a class="nav-link" href="#services">Services</a></li>
                        <li class="nav-item"><a class="nav-link" href="#portfolio">Portfolio</a></li>
                        <!--<li class="nav-item"><a class="nav-link" href="/login" id="btnmasuk">Login</a></li>-->

                        <li class="nav-item">
                            <% if (user) { %>
                                <a class="nav-link" href="/logout">
                                    <i class="bi bi-person-circle"></i> <%= user %> | Logout
                                </a>
                            <% } else { %>
                                <a class="nav-link" href="/login">
                                    Login
                                </a>
                            <% } %>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
        <!-- Masthead-->
        <header class="masthead">
            <div class="container px-4 px-lg-5 h-100">
                <div class="row gx-4 gx-lg-5 h-100 align-items-center justify-content-center text-center">
                    <div class="col-lg-8 align-self-end">
                        <h1 class="text-white font-weight-bold">MANAJEMEN PENGOLAHAN DATA KINERJA</h1>
                        <hr class="divider" />
                    </div>
                    <div class="col-lg-8 align-self-baseline">
                        <p class="text-white-75 mb-5">Start untuk melakukan proses penilaian karyawan</p>
                        <button class="btn btn-primary flex-fill nav-btn" data-url="/penilaian">
                            Form Penilaian
                        </button>

                        <button class="btn btn-secondary flex-fill nav-btn" data-url="/karyawan">
                            Form Karyawan
                        </button>

                        <button class="btn btn-secondary flex-fill nav-btn" data-url="/mlogin">
                            Form Manajemen user
                        </button>

                        <button class="btn btn-secondary flex-fill nav-btn" data-url="/reffnilai">
                            Isi Data Parameter
                        </button>
                        </div>
                    </div>
                </div>
            </div>
        </header>
        <!-- About-->
        <section class="page-section bg-primary" id="about">
            <div class="container px-4 px-lg-5">
                <div class="row gx-4 gx-lg-5 justify-content-center">
                    <div class="col-lg-8 text-center">
                        <h2 class="text-white mt-0">Apa itu Aplikasi Penilaian Kinerja!</h2>
                        <hr class="divider divider-light" />
                        <p class="text-white-75 mb-4">Aplikasi penilaian Kinerja adalah tools untuk reward/punishment berdasarkan kinerja karyawan yang meliputi kedisiplinan dan motivasi kerja!</p>
                        <!--<a class="btn btn-light btn-xl" href="#services">Get Started!</a>-->
                    </div>
                </div>
            </div>
        </section>
        <!-- Services-->
        <section class="page-section" id="services">
            <div class="container px-4 px-lg-5">
                <h2 class="text-center mt-0">At Your Service</h2>
                <hr class="divider" />
                <div class="row gx-4 gx-lg-5">
                    <div class="col-lg-3 col-md-6 text-center">
                        <div class="mt-5">
                            <div class="mb-2"><i class="bi-gem fs-1 text-primary"></i></div>
                            <h3 class="h4 mb-2">Database/ host</h3>
                            <p class="text-muted mb-0">Using postgree database on supabase and Vercell hosting</p>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 text-center">
                        <div class="mt-5">
                            <div class="mb-2"><i class="bi-laptop fs-1 text-primary"></i></div>
                            <h3 class="h4 mb-2">Limited data</h3>
                            <p class="text-muted mb-0">Make sure data for 1 year only, when the year changes, backup data, delete all in transaction table only. start with the new year</p>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 text-center">
                        <div class="mt-5">
                            <div class="mb-2"><i class="bi-globe fs-1 text-primary"></i></div>
                            <h3 class="h4 mb-2">IT/EDP support</h3>
                            <p class="text-muted mb-0">This application receives support from EDP for technical issues. Using the application and data is the responsibility of the end user.!</p>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 text-center">
                        <div class="mt-5">
                            <div class="mb-2"><i class="bi-heart fs-1 text-primary"></i></div>
                            <h3 class="h4 mb-2">Made with Love</h3>
                            <p class="text-muted mb-0">The application is created with a love for knowledge that can be applied and is useful.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Footer-->
        <footer class="bg-light py-5">
            <div class="container px-4 px-lg-5"><div class="small text-center text-muted">Copyright &copy; 2026 - PT. K-Link Indonesia</div></div>
        </footer>
        <!-- Bootstrap core JS-->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
        <!-- SimpleLightbox plugin JS-->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/SimpleLightbox/2.1.0/simpleLightbox.min.js"></script>
        <!-- Core theme JS-->
        <script src="/js/scripts.js"></script>
        <!-- * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * *-->
        <!-- * *                               SB Forms JS                               * *-->
        <!-- * * Activate your form at https://startbootstrap.com/solution/contact-forms * *-->
        <!-- * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * *-->
        <!--<script src="https://cdn.startbootstrap.com/sb-forms-latest.js"></script>-->

        <script>
        document.addEventListener("DOMContentLoaded", function () {

            const isLogin = document.body.dataset.login === "true";
            const buttons = document.querySelectorAll(".nav-btn"); //karena tombol2 utama dikasih tag nav-btn

            buttons.forEach(btn => {

                // disable tampilan kalau belum login
                if (!isLogin) {
                    btn.classList.add("disabled");
                }

                btn.addEventListener("click", function () {
                    if (!isLogin) {
                        alert("Harus login terlebih dahulu!");
                        return;
                    }

                    window.location.href = this.dataset.url;
                });
            });

        });
        </script>

    </body>
</html>
