
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Penilaian</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: #f1f5f9;
    }

    .navbar {
      background: #0d6efd;
    }

    .card {
      border-radius: 15px;
    }

    table th {
      background: #0d6efd;
      color: white;
    }
  </style>
</head>

<body>

  <!-- NAVBAR -->
  <nav class="navbar navbar-dark px-3">
    <span class="navbar-brand">Dashboard Penilaian</span>
    <a href="/penilaian" class="btn btn-light btn-sm">Input Nilai</a>
  </nav>

  <div class="container mt-4">

    <div class="card shadow">
      <div class="card-body">

        <div class="d-flex justify-content-between mb-3">
          <h4>Data Nilai</h4>
          <button class="btn btn-primary btn-sm" onclick="loadData()">Refresh</button>
        </div>

        <table class="table table-bordered table-striped">
          <thead>
            <tr>
              <th>ID</th>
              <th>Nama</th>
              <th>Mata Pelajaran</th>
              <th>Nilai</th>
              <th>Tanggal</th>
            </tr>
          </thead>
          <tbody id="dataTable">
            <!-- DIISI OTOMATIS -->
          </tbody>
        </table>

      </div>
    </div>

  </div>

  <script>
    async function loadData() {
      const res = await fetch("/api/nilai");
      const data = await res.json();

      let html = "";
      data.forEach(d => {
        html += `
          <tr>
            <td>${d.ID}</td>
            <td>${d.NAMA}</td>
            <td>${d.MAPEL}</td>
            <td>${d.NILAI}</td>
            <td>${d.TANGGAL}</td>
          </tr>
        `;
      });

      document.getElementById("dataTable").innerHTML = html;
    }

    loadData();
  </script>

</body>

</html>