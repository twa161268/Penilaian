<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Form Penilaian Karyawan</title>

    <!-- BOOTSTRAP -->
    
    <!--<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">-->
    
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/icons/bootstrap-icons.css">
    <style>
        body {
            background: #f3f6fa;
        }

        .panel-left {
            background: white;
            border-radius: 8px;
            padding: 20px;
            height: 95vh;
            overflow-y: auto;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        }

        .panel-right {
            background: white;
            border-radius: 8px;
            padding: 20px;
            height: 95vh;
            overflow-y: auto;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        }

        .ref-box, .hasil-box {
            background: #f1f7ff;
            padding: 6px;
            border-radius: 6px;
            text-align: center;
            font-weight: bold;
        }

        table tbody tr:hover {
            background: #dceeff;
            cursor: pointer;
        }

        .tx-input {
            width: 80px;
        }

        .text-end {
            text-align: right;
        }


    </style>
</head>

<body>

<div class="container-fluid mt-3">
    <div class="row">

        <!-- =============================== -->
        <!-- PANEL KIRI - FORM PENILAIAN    -->
        <!-- =============================== -->
        <div class="col-4 panel-left">

            <h4 class="mb-3">Form Penilaian Karyawan</h4>

            <label class="form-label fw-bold">Periode</label>
            <input type="month" id="periode" class="form-control mb-3">

            <label class="form-label fw-bold">Nilai Bonus</label>
            <input id="bonus" class="form-control mb-4">

            <button id="btnLoad" type=button class="btn btn-primary w-100 mb-3">Load Data</button>
            <button id="btnTambah" type=button class="btn btn-success w-100 mb-3">Generate data penilaian baru perperiode</button>

            <hr>

            <label class="form-label fw-bold">ID Karyawan</label>
            <input id="idk" class="form-control mb-2" readonly>

            <label class="form-label fw-bold">Nama Karyawan</label>
            <input id="nama" class="form-control mb-2" readonly>

            <label class="form-label fw-bold">Jabatan</label>
            <div id="jabatan" class="form-control mb-3 bg-light"></div>



            <!-- ================== -->
            <!-- FORM TX & REF     -->
            <!-- ================== -->
            <h5 class="mt-4">Komponen Penilaian</h5>

            <table class="table table-bordered small">
                <thead>
                <tr>
                    <th>Kode</th>
                    <th>Nilai</th>
                    <th>Ref</th>
                    <th>Hasil</th>
                </tr>
                </thead>

                <tbody>
                <% 
                    const komponen = [
                        "-","Cuti Sakit","Telat diatas 30 min","Telat dibawah 30 min","Telat diatas 60 Min","Lupa Absen",
                        "Hadir Full","Hadir Ontime","Overtime (min)","Kerja hari libur","Reward",
                        "Kerja Lalai","Tunda pekerjaan","Alpha"
                    ];
                    for (let i = 1; i <= 13; i++) { 
                %>
                    <tr>
                        <td><%= komponen[i] %></td>
                        <td><input id="tx<%= i %>" class="form-control tx-input"></td>
                        <td><div id="ref<%= i %>" class="ref-box"></div></td>
                        <td><div id="hasil<%= i %>" class="hasil-box"></div></td>
                    </tr>
                <% } %>
                </tbody>
            </table>

            <label class="form-label fw-bold">Total Nilai</label>
            <div id="totalnilai" class="form-control mb-3 bg-light">0</div>

            <label class="form-label fw-bold">Total %</label>
            <div id="totalpersen" class="form-control mb-3 bg-light">0</div>
            
            <label class="form-label fw-bold">Surplus/Minus</label>
            <div id="sumin" class="form-control mb-3 bg-light">0</div>
            
            <label class="form-label fw-bold">Jumlah Bonus</label>
            <div id="jmlbonus" class="form-control mb-3 bg-light">0</div>
            
            <label class="form-label fw-bold">Bonus Actual</label>
            <div id="bonusactual" class="form-control mb-3 bg-light">0</div>
            
            <button id="btnSimpan" type=button class="btn btn-primary w-100 mb-3">Simpan Data</button>
            <button id="btnRepof" type=button class="btn btn-primary w-100 mb-3">Cetak Form ini</button>



        </div>


        <!-- =============================== -->
        <!-- PANEL KANAN - LISTING           -->
        <!-- =============================== -->
        <div class="col-8 panel-right">


        <div class="d-flex justify-content-end align-items-center gap-2 mb-2">
            <button id="btnRepof2" type=button class="btn btn-success btn-sm me-4" >Cetak Form</button>
            <!-- SEARCH -->
            <button id="btnCari" class="btn btn-info btn-sm text-white">
                <i class="bi bi-search"></i>
            </button>

            <input id="cari" class="form-control form-control-sm" style="width: 250px;">

            <!-- DELETE -->
            <button id="btnDelete" class="btn btn-info btn-sm ms-3 text-white">
                <i class="bi bi-trash"></i>
            </button>

            <input type="checkbox" id="chkHeader" style="transform: scale(1.3); margin-left: 5px;">

        </div>

        <h4>Listing Penilaian Data Karyawan</h4>
            <table class="table table-striped" id="tblPenilaian">
                <thead class="table-dark">
                <tr>
                    <th>PERIOD</th>
                    <th>ID</th>
                    <th>NAMA</th>
                    <th>TOTALPERSEN</th>
                    <th>BNSACTUAL</th>
                    <th class="text-center">✓</th>

                </tr>
                </thead>
                <tbody></tbody>
            </table>

        </div>

    </div>
</div>

<!-- JS -->
<!--<script src="/js/penilaian.js"></script>-->
<script src="/js/penilaian.js?v=2"></script>
<script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>